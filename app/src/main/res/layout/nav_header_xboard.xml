<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/xboard_header_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="星隧互联"
        android:textAppearance="?attr/textAppearanceHeadline6"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/xboard_header_email"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textAppearance="?attr/textAppearanceBody2" />

    <TextView
        android:id="@+id/xboard_header_plan"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:textAppearance="?attr/textAppearanceBody2" />

    <TextView
        android:id="@+id/xboard_header_traffic"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_xboard_chip"
        android:paddingLeft="12dp"
        android:paddingTop="8dp"
        android:paddingRight="12dp"
        android:paddingBottom="8dp"
        android:textAppearance="?attr/textAppearanceBody2"
        android:textColor="#1F2937" />

    <TextView
        android:id="@+id/xboard_header_expiry"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textAppearance="?attr/textAppearanceBody2" />
</LinearLayout>
